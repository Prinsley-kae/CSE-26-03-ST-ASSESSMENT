doctype html
html(lang="en")
  head
    title Videx Dashboard
    link(rel="stylesheet", href="/css/style.css")

  body
    header.header
      .logo
        //- SVG Video Icon for the logo
        svg(width="50" height="50" viewBox="0 0 24 24" fill="#ff0000" style="vertical-align: middle; margin-right: 10px;")
          circle(cx="12" cy="12" r="10" fill="#ff0000")
          path(d="M10 8L16 12L10 16V8Z" fill="#ffffff")
        | Videx

      a(href="/upload")
        button.add-btn Add Video

    h2.section-title Videos

    .video-grid
      each video in videos
        .video-card
          //- Video Player
          video(width="100%", controls, style="border-radius: 8px; background: #000;")
            source(src="/uploads/" + video.videoPath, type="video/mp4")
            | Your browser does not support the video tag.

          .video-info
            .title= video.title
            .meta #{video.views || '0'} views • #{video.age || 'Recently'}